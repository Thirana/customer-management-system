{
  "info": {
    "_postman_id": "8f45c31a-78b6-43b2-b35a-f9b941a6f34b",
    "name": "Customer Management API",
    "description": "Postman collection for the Customer Management System backend. Import this with the local environment file and run the backend at {{baseUrl}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Master Data",
      "item": [
        {
          "name": "List Cities",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cities",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cities"
              ]
            },
            "description": "Returns all city and country values for customer address dropdowns."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers?page={{page}}&size={{size}}&sortBy={{sortBy}}&sortDir={{sortDir}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "size",
                  "value": "{{size}}"
                },
                {
                  "key": "sortBy",
                  "value": "{{sortBy}}"
                },
                {
                  "key": "sortDir",
                  "value": "{{sortDir}}"
                }
              ]
            },
            "description": "Returns a paginated customer summary list. Supported sortBy values: id, name, nicNumber, dateOfBirth."
          },
          "response": []
        },
        {
          "name": "Get Customer Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "{{customerId}}"
              ]
            },
            "description": "Returns full customer detail for the parameterized customer ID."
          },
          "response": []
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{customerName}}\",\n  \"dateOfBirth\": \"{{dateOfBirth}}\",\n  \"nicNumber\": \"{{nicNumber}}\",\n  \"mobileNumbers\": {{customerMobileNumbers}},\n  \"addresses\": {{customerAddresses}},\n  \"familyMemberIds\": {{customerFamilyMemberIds}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers"
              ]
            },
            "description": "Creates a customer. Change nicNumber if you rerun without deleting the created customer."
          },
          "response": []
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{updatedCustomerName}}\",\n  \"dateOfBirth\": \"{{updatedDateOfBirth}}\",\n  \"nicNumber\": \"{{updatedNicNumber}}\",\n  \"mobileNumbers\": {{updatedCustomerMobileNumbers}},\n  \"addresses\": {{updatedCustomerAddresses}},\n  \"familyMemberIds\": {{updatedCustomerFamilyMemberIds}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "{{customerId}}"
              ]
            },
            "description": "Updates the parameterized customer ID. Use the same nicNumber to avoid duplicate NIC conflicts, or provide a unique value."
          },
          "response": []
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "{{customerId}}"
              ]
            },
            "description": "Deletes the parameterized customer ID."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Examples",
      "item": [
        {
          "name": "Get Missing Customer",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/{{missingCustomerId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "{{missingCustomerId}}"
              ]
            },
            "description": "Expected to return a 404 ApiResponse envelope."
          },
          "response": []
        },
        {
          "name": "Create Customer Validation Error",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Request-ID",
                "value": "{{requestId}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"\",\n  \"dateOfBirth\": null,\n  \"nicNumber\": \"\",\n  \"mobileNumbers\": [],\n  \"addresses\": [],\n  \"familyMemberIds\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "customers"
              ]
            },
            "description": "Expected to return a 400 validation error envelope."
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.variables.set('requestId', 'postman-' + Date.now());"
        ]
      }
    }
  ]
}
